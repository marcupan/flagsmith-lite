# API base URL — change to your deployed API URL in staging/production
VITE_API_URL=http://localhost:3000

# API key for protected endpoints (must match API_KEY in apps/api/.env)
VITE_API_KEY=change-me-in-production

# PostHog analytics (optional — omit for local dev without tracking)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com
